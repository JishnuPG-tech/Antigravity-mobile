# Telegram bot token
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
AUTHORIZED_USERS=123456789

# Where workspaces are stored inside the container (Hugging Face Spaces persistent volume)
WORKSPACE_PATH=/data/workspaces

# Max upload size in bytes
UPLOAD_LIMIT=104857600

# Session timeout seconds (unused in scaffold)
SESSION_TIMEOUT=86400

# Log level
LOG_LEVEL=INFO
